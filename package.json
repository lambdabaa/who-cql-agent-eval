{
  "name": "who-cql-agent-eval",
  "version": "0.0.1",
  "description": "Evaluation harness for AI agents authoring/modifying/reasoning about WHO SMART Guidelines CQL",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "who-eval": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx src/cli.ts run",
    "eval:measles": "tsx src/cli.ts run --dak smart-immunizations --table IMMZD2DTMeaslesLowTransmissionLogic",
    "baseline:build": "tsx src/cli.ts baseline build",
    "baseline:run": "tsx src/cli.ts baseline run",
    "baseline:grade": "tsx src/cli.ts baseline grade"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cql-execution": "^3.2.0",
    "cql-exec-fhir": "^2.1.5",
    "yaml": "^2.6.0",
    "zod": "^3.23.8",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
